#############################################################
#
#       ACMI Database for pscDrv IOC
#      
#
#############################################################

# Flush reg to socket buffer, trigger send to send all socket buffer to PSC 
record(bo, "$(P){ACMI2:$(NO)}send") { 
    field(DTYP, "PSC Ctrl Send All") 
    field(OUT , "@PSC$(NO)") 
    field(ZNAM, "Send") 
    field(ONAM, "Send") 
} 
 
# Write a single register
record(longout, "$(P){ACMI2:$(NO)}GoRegSingleWrite") {
    field(DTYP, "PSC Ctrl Send")
    field(OUT , "@PSC$(NO)")
    field(VAL , "1") 
    field(FLNK, "$(P){ACMI2:$(NO)}send")
}

# Write a single register
record(longout, "$(P){ACMI2:$(NO)}GoRegSingleWrite2") {
    field(DTYP, "PSC Ctrl Send")
    field(OUT , "@PSC$(NO)")
    field(VAL , "2") 
    field(FLNK, "$(P){ACMI2:$(NO)}send")
}

# Write a single register
record(longout, "$(P){ACMI2:$(NO)}GoRegSingleWrite5") {
    field(DTYP, "PSC Ctrl Send")
    field(OUT , "@PSC$(NO)")
    field(VAL , "5") 
    field(FLNK, "$(P){ACMI2:$(NO)}send")
}


############# Control PV's ##########################################

record(bo, "$(P){ACMI2:$(NO)}KeepAlive-SP") {
    field(DESC, "Keeps the socket active")
    field(DTYP, "PSC Single U32")
    field(OUT , "@PSC$(NO) 5 100")
    field(SCAN, "1 second")
    field(FLNK, "$(P){ACMI2:$(NO)}GoRegSingleWrite5")
}

# Triggered by EVR now, this is no longer supported
record(bo, "$(P){ACMI2:$(NO)}FaultLatchReset-SP") {
    field(DESC, "Soft Trigger by user")
    field(DTYP, "PSC Single U32")
    field(OUT , "@PSC$(NO) 1 8")
    #field(SCAN, "1 second")   
    field(FLNK, "$(P){ACMI2:$(NO)}GoRegSingleWrite")
}

record(bo, "$(P){ACMI2:$(NO)}Trig:TrigSrc-SP") {
    field(DESC, "Trigger source")
    field(DTYP, "PSC Single U32")
    field(OUT , "@PSC$(NO) 1 52")
    field(ZNAM,"EXT")
    field(ONAM,"INT")
    info(autosaveFields, "VAL")
    field(FLNK, "$(P){ACMI2:$(NO)}GoRegSingleWrite")
}

record(longout, "$(P){ACMI2:$(NO)}EVR:TrigNo-SP") {
    field(DESC, "EVR Trigger Number")
    field(DTYP, "PSC Single I32")
    field(OUT , "@PSC$(NO) 1 0")
    info(autosaveFields, "VAL")
    field(FLNK, "$(P){ACMI2:$(NO)}GoRegSingleWrite")
}

record(longout, "$(P){ACMI2:$(NO)}EVR:TrigDly-SP") {
    field(DESC, "EVR Trigger Delay")
    field(DTYP, "PSC Single I32")
    field(OUT , "@PSC$(NO) 1 4")
    info(autosaveFields, "VAL")
    field(FLNK, "$(P){ACMI2:$(NO)}GoRegSingleWrite")
}

record(ai,"$(P){ACMI2:$(NO)}TS-S-I") {
    field(DESC, "EVR Timestamp (s)")
    field(DTYP, "PSC Reg")
    field(INP , "@PSC$(NO) 55 0 ")
    field(SCAN, "I/O Intr")
}

record(ai,"$(P){ACMI2:$(NO)}TS-NS-I") {
    field(DESC, "EVR Timestamp (ns)")
    field(DTYP, "PSC Reg")
    field(INP , "@PSC$(NO) 55 4 ")
    field(SCAN, "I/O Intr")
}

record(waveform,"$(P){ACMI2:$(NO)}Trig:Date-I"){
  field(DTYP,"Soft Channel")
  field(DESC,"String for Trigger Date")
  field(NELM,"40")
  field(FTVL,"CHAR")
}

record(waveform,"$(P){ACMI2:$(NO)}Settings:File-SP"){
  field(DTYP,"Soft Channel")
  field(DESC,"String for Trigger Date")
  field(NELM,"128")
  field(FTVL,"CHAR")
}

record(longout,"$(P){ACMI2:$(NO)}File:Status-I") {
  field(DTYP,"Soft Channel")
  field(VAL,0)
  field(UDF,0)
}

record(compress, "$(P){ACMI2:$(NO)}PM:Fault-Wfm"){
    field(INP,  "$(P){ACMI2:$(NO)}faults_lat-I")     # source PV
    field(ALG,  "Circular Buffer")  
    field(NSAM, "2")             # buffer length = 2
}

